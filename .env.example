# ── Sendblue (iMessage gateway) ── set in Wave 0 after sandbox signup
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=

# Self-minted webhook URL token (embed in the registered webhook URL as ?t=<token>).
# Sendblue has NO inbound signing secret — this is yours. Generate: openssl rand -hex 24
WEBHOOK_URL_TOKEN=

# ── Postgres (Neon recommended) ── MUST be a TCP/SESSION connection string.
# neon-http has NO transaction support; use the direct/session string with postgres-js.
DATABASE_URL=

# ── OpenRouter (single key for all model calls) ── https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: defaults to the fastest verified free tool-capable model below.
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# Optional comma-separated fallbacks. Use `none` to force only OPENROUTER_MODEL.
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free,openai/gpt-oss-120b:free

# ── Single-user allowlist (E.164, e.g. +639XXXXXXXXX) ──
ALLOWED_PHONE=

# ── Vercel Cron auth ── MUST be named exactly CRON_SECRET. Generate: openssl rand -hex 24
CRON_SECRET=
