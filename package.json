{
  "name": "andy",
  "version": "0.0.0",
  "private": true,
  "description": "An iMessage personal finance assistant: natural-language transactions, budgets, goals, recurring reminders, and memories with an AI SDK agent, exact integer-centavo math, and atomic dedup. Bun monorepo, serverless on Vercel.",
  "license": "MIT",
  "author": "ndycode",
  "homepage": "https://github.com/ndycode/andy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ndycode/andy.git"
  },
  "bugs": {
    "url": "https://github.com/ndycode/andy/issues"
  },
  "keywords": [
    "imessage",
    "personal-finance",
    "budgeting",
    "savings-goals",
    "recurring-reminders",
    "ai-agent",
    "ai-sdk",
    "openrouter",
    "hono",
    "drizzle",
    "postgres",
    "bun",
    "typescript",
    "vercel",
    "serverless"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "./build-vercel.sh",
    "ci:local": "./scripts/ci-local.sh",
    "typecheck": "turbo typecheck && tsc --noEmit -p tsconfig.json",
    "test": "turbo test",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "lint:no-excuse": "bun run scripts/typescript/check-no-excuse-rules.ts packages/shared/src packages/db/src packages/ai/src apps/api/src api",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
